    },
    {
      "parameters": {
        "jsCode": "// Get the original search keyword from the form\nconst keyword = $('YouTube_Topic_Form').first().json[\"Keyword or Topic\"] || '';\nconst keyWords = keyword.toLowerCase().split(' ').filter(w => w.length > 2);\n\nif (keyWords.length === 0) return $input.all();\n\n// Score each video: how many keywords appear in title or description\nconst scored = $input.all().map(item => {\n  const title = (item.json.snippet?.title || '').toLowerCase();\n  const desc = (item.json.snippet?.description || '').toLowerCase();\n  const matchCount = keyWords.filter(w => title.includes(w) || desc.includes(w)).length;\n  const score = matchCount / keyWords.length;\n  return { item, score };\n});\n\n// Sort by relevance score descending, keep top half (at least 5)\nscored.sort((a, b) => b.score - a.score);\nconst minKeep = Math.min(5, scored.length);\nconst threshold = Math.max(0.25, scored[minKeep - 1]?.score || 0);\n\nconst filtered = scored\n  .filter(s => s.score >= threshold)\n  .map(s => s.item);\n\nreturn filtered.length > 0 ? filtered : $input.all().slice(0, 5);"
      },
      "id": "relevance-filter-id",
      "name": "Relevance_Filter",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        432,
        0
      ]
    }
