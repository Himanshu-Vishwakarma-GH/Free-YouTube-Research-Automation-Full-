    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Extract JSON from the AI analysis agent's text output\nconst agentOutput = $json.output || '';\nlet analysisData = {};\ntry {\n  const jsonMatch = agentOutput.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) { analysisData = JSON.parse(jsonMatch[0]); }\n} catch(e) { analysisData = {}; }\n\n// Pull video metadata from Transcript_Scraper\nconst videoData = $('Transcript_Scraper').item.json;\n\nreturn {\n  json: {\n    videoId: videoData.videoId || '',\n    originalTitle: videoData.title || '',\n    thumbnail: videoData.thumbnail || '',\n    videoViews: videoData.videoViews || '0',\n    channelSubscribers: videoData.channelSubscribers || '0',\n    transcript: (videoData.transcript || '').slice(0, 1500),\n    newTitle: analysisData.newTitle || '',\n    thumbnailText: analysisData.thumbnailText || '',\n    newOutline: analysisData.newOutline || '',\n    viralReason: analysisData.viralReason || ''\n  }\n};"
      },
      "id": "parse-output-id",
      "name": "Parse_Agent_Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        336
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are writing a production-ready YouTube script for a creator researching the topic: \"{{ $('YouTube_Topic_Form').first().json[\"Keyword or Topic\"] }}\"\n\n=== VIRAL VIDEO ANALYSIS (Module 1 Output) ===\nOriginal Title: {{ $json.originalTitle }}\nVideo Views: {{ $json.videoViews }}\nChannel Subscribers: {{ $json.channelSubscribers }}\nWhy It Went Viral: {{ $json.viralReason }}\nNew Optimized Title: {{ $json.newTitle }}\nContent Outline: {{ $json.newOutline }}\n\n=== ORIGINAL VIDEO TRANSCRIPT (Content Reference) ===\n{{ $json.transcript }}\n\n=== YOUR TASK ===\nWrite a NEW, original YouTube script INSPIRED by this viral video on the topic: \"{{ $('YouTube_Topic_Form').first().json[\"Keyword or Topic\"] }}\"\nDo NOT copy the original. Use it as research to write something better.\n\nReturn ONLY valid JSON:\n{\n  \"hook\": \"First 30 seconds: bold claim + pattern interrupt to stop the scroll\",\n  \"body\": \"Full script with [Section 1], [Section 2], [Section 3] — each 150-200 words of actual script\",\n  \"cta\": \"End screen subscribe CTA + tease next related video\",\n  \"thumbnailConcepts\": [\"Visual concept 1 (describe the image)\", \"Visual concept 2\", \"Visual concept 3\"],\n  \"seoTitle\": \"SEO-optimized title under 60 characters for the topic\",\n  \"seoDescription\": \"2-3 paragraph YouTube description with keywords and timestamps placeholder\",\n  \"seoTags\": [\"tag1\", \"tag2\", \"tag3\", \"tag4\", \"tag5\", \"tag6\", \"tag7\"]\n}",
        "options": {}
      },
      "id": "script-agent-id",
      "name": "Script_Generator_Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        688,
        336
      ]
    },
    {
      "parameters": {
        "model": "nvidia/nemotron-3-nano-30b-a3b:free",
        "options": {}
      },
      "id": "script-model-id",
      "name": "OpenRouter_Script_Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenRouter",
      "typeVersion": 1,
      "position": [
        592,
        512
      ],
      "credentials": {
        "openRouterApi": {
          "id": "dYmjYCq5S18vnbti",
          "name": "OpenRouter account"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Parse the Script Generator agent's JSON output safely\nconst agentOutput = $json.output || '';\nlet scriptData = {};\n\nif (agentOutput.trim()) {\n  try {\n    const jsonMatch = agentOutput.match(/\\{[\\s\\S]*\\}/);\n    if (jsonMatch) { scriptData = JSON.parse(jsonMatch[0]); }\n  } catch(e) {\n    scriptData = { hook: agentOutput.slice(0, 500), body: '', cta: '', thumbnailConcepts: [], seoTitle: '', seoDescription: '', seoTags: [] };\n  }\n}\n\n// If no output from AI (empty response), skip this item gracefully\nif (!agentOutput.trim()) {\n  return [];\n}\n\n// Get enriched analysis data from Module 1\nconst a = $('Parse_Agent_Output').item.json;\nconst searchTopic = $('YouTube_Topic_Form').first().json['Keyword or Topic'] || '';\n\nreturn {\n  json: {\n    Timestamp: new Date().toISOString(),\n    Search_Topic: searchTopic,\n    Video_ID: a.videoId || '',\n    Original_Title: a.originalTitle || '',\n    Video_Views: a.videoViews || '',\n    Channel_Subscribers: a.channelSubscribers || '',\n    Viral_Reason: a.viralReason || '',\n    New_Title: a.newTitle || '',\n    Thumbnail_Text: a.thumbnailText || '',\n    SEO_Title: scriptData.seoTitle || '',\n    Hook_Script: scriptData.hook || '',\n    Body_Script: scriptData.body || '',\n    CTA_Script: scriptData.cta || '',\n    Thumbnail_Concepts: Array.isArray(scriptData.thumbnailConcepts) ? scriptData.thumbnailConcepts.join(' | ') : '',\n    SEO_Description: scriptData.seoDescription || '',\n    SEO_Tags: Array.isArray(scriptData.seoTags) ? scriptData.seoTags.join(', ') : '',\n    Thumbnail_URL: a.thumbnail || ''\n  }\n};"
      },
      "id": "build-row-id",
      "name": "Build_Sheet_Row",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        336
      ]
    },
    {
      "parameters": {
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1,
      "position": [
        704,
        512
      ],
      "id": "76afe43f-0a49-4be3-8a1b-b602dcf6357a",
      "name": "Google Gemini Chat Model1",
      "credentials": {
        "googlePalmApi": {
          "id": "j2cYYOfKet9UXjWn",
          "name": "Google Gemini(PaLM) Api account"
        }
