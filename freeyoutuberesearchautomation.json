    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const videoId = $('Extract_Video').item.json.id;\nconst title = $('Extract_Video').item.json.snippet.title;\nconst thumbnails = $('Extract_Video').item.json.snippet.thumbnails;\nconst thumbnail = thumbnails.maxres ? thumbnails.maxres.url : (thumbnails.high ? thumbnails.high.url : thumbnails.medium.url);\nconst channelSubscribers = $json.statistics.subscriberCount;\nconst videoViews = $('Extract_Video').item.json.statistics.viewCount;\n\nlet transcript = 'No transcript available';\ntry {\n  const res = await this.helpers.httpRequest({\n    method: 'GET',\n    url: `https://youtube-transcript.vercel.app/api/transcript?id=${videoId}`,\n  });\n  if (Array.isArray(res)) {\n    transcript = res.map(t => t.text).join(' ');\n  } else {\n    transcript = JSON.stringify(res).slice(0, 3000);\n  }\n} catch(e) {\n  transcript = 'Transcript unavailable: ' + e.message;\n}\n\nreturn {\n  json: {\n    videoId,\n    title,\n    thumbnail,\n    channelSubscribers,\n    videoViews,\n    transcript\n  }\n};"
